# Скопировать в /opt/domain-controller/.env и заполнить.
# chmod 600, owner root (содержит SECRET_KEY и пароль БД).
#
#   cp deploy/env.example /opt/domain-controller/.env
#   sudo chmod 600 /opt/domain-controller/.env
#   sudo chown root:root /opt/domain-controller/.env
#
# install.sh заполняет SECRET и DATABASE_URL автоматически.

# ─────────── Обязательные ───────────

# Секрет для подписи сессионных cookie.
# Генерация: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Без этого приложение откажется стартовать.
DC_PANEL_SECRET=REPLACE_ME_WITH_A_LONG_RANDOM_STRING

# PostgreSQL connection string. Обязательна — SQLite в production не используется.
# install.sh создаёт юзера/БД и подставляет правильный URL автоматически.
DATABASE_URL=postgresql+psycopg2://dc_user:CHANGEME@127.0.0.1:5432/dc

# Email для Let's Encrypt — туда идут уведомления об истечении сертификатов.
LETSENCRYPT_EMAIL=admin@example.com

# ─────────── Опциональные ───────────

# DEV_MODE=1 — локальная разработка: nginx/certbot не вызываются, fallback на SQLite
# (data.db рядом с app.py). На продакшн-сервере должно быть 0 (или строка отсутствует).
DEV_MODE=0

# URL для POST-уведомлений о событиях
#   (certbot_failed, letsencrypt_nginx_failed, backend_down, ssl_expiring_soon).
# POST JSON: {"event":"...","domain":"...","details":"...","timestamp":"..."}.
# Если пусто — уведомления выключены.
# DC_WEBHOOK_URL=https://hooks.example.com/domain-controller

# Токен для защиты /metrics. Если задан — Prometheus scraper должен слать
# `Authorization: Bearer <token>`. Если пусто — /metrics открыт (для LAN-мониторинга
# через nginx whitelist).
# DC_METRICS_TOKEN=
